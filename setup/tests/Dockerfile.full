FROM ubuntu:24.04
ENV DEBIAN_FRONTEND=noninteractive
ENV PATH="/root/.local/bin:/root/.cargo/bin:${PATH}"
# Canonical layout: SYNC_ROOT defaults to $HOME/synced via .vars.
# Full base+shell+dev install (~30 min). Run via: make docker-test

RUN apt-get update && apt-get install -y sudo curl git make stow && \
    rm -rf /var/lib/apt/lists/* && \
    echo 'root ALL=(ALL) NOPASSWD: ALL' >> /etc/sudoers && \
    rm -f /root/.profile

WORKDIR /root/synced/composites/pkm/diencephalon
COPY . .

RUN make install-uv && \
    make setup-run PROFILES="shell dev" && \
    make setup-verify PROFILES="shell dev"
