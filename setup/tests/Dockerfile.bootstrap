FROM ubuntu:24.04
ENV DEBIAN_FRONTEND=noninteractive
ENV HOME=/root
ENV USER=root
ENV PATH="/root/.local/bin:/root/.cargo/bin:${PATH}"

# Minimal pre-bootstrap state: curl + git only. bootstrap.sh installs the rest.
RUN apt-get update && apt-get install -y sudo curl git ca-certificates && \
    rm -rf /var/lib/apt/lists/* && \
    echo 'root ALL=(ALL) NOPASSWD: ALL' >> /etc/sudoers

# Stage the diencephalon repo as a local clone source. bootstrap.sh then
# `git clone $DIENCEPHALON_URL` to the canonical synced location.
COPY . /tmp/diencephalon-src

# Ubuntu's stock /root/.profile would conflict with the stow symlink restow creates.
RUN rm -f /root/.profile

# Exercises: arg parsing, git clone to canonical layout, restow, make setup-run.
RUN DIENCEPHALON_URL=/tmp/diencephalon-src bash /tmp/diencephalon-src/setup/bootstrap.sh --tier guest

# Independent verify after bootstrap completes (PROFILES= so we verify only base).
WORKDIR /root/synced/composites/pkm/diencephalon
RUN make setup-verify PROFILES=
