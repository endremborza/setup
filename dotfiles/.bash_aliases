# Public aliases (diencephalon)

[ -f ~/.local-aliases ] && . ~/.local-aliases
alias clopuh="claude --model claude-opus-4-6 --effort high"
alias clopum="claude --model claude-opus-4-6 --effort max"
alias clsoh="claude --model claude-sonnet-4-6 --effort high"
alias gwc="watch -n 1 -c git -c color.status=always status"
