#!/bin/bash

# === Ecosystem root (single source of truth) ===
# Default: $HOME/synced. On hosts where the synced tree lives elsewhere,
# either symlink ~/synced → that-location (preferred), or override SYNC_ROOT
# in .local-vars (requires re-deriving the per-path exports below).
: "${SYNC_ROOT:=$HOME/synced}"
export SYNC_ROOT

# === Derived paths ===
export DIEN_ROOT="$SYNC_ROOT/composites/pkm/diencephalon"
export HYPO_ROOT="$SYNC_ROOT/composites/pkm/hypothalamus"
export LOGOS_ROOT="$SYNC_ROOT/composites/pkm/logos"

export CODE_DIR="$SYNC_ROOT/code"
export COMPOSITES_DIR="$SYNC_ROOT/composites"
export FOLIOS_DIR="$SYNC_ROOT/folios"
export DATA_DIR="$SYNC_ROOT/data"
export ASSETS_DIR="$SYNC_ROOT/assets"
export MEDIA_DIR="$SYNC_ROOT/media"
export SHARE_DIR="$SYNC_ROOT/share"
export ARCHIVE_DIR="$SYNC_ROOT/archive"
export LOGS_DIR="$SYNC_ROOT/logs"

# === Tool config ===
# uv hardlinks venv contents from its cache; cache must sit on the same volume
# as $SYNC_ROOT. Co-locating it under $SYNC_ROOT makes this automatic.
export UV_CACHE_DIR="$SYNC_ROOT/.cache/uv"
export UV_TOOL_DIR="$SHARE_DIR/uv-tools"
export VISUAL=nvim
export EDITOR=nvim

# === Fleet identity ===
# The hub is the one machine that runs primary-only operations (rclone offsite
# sync, git-bare backups) and holds logos. Tools gated on hub identity check
# `hostname == $PRIMARY_HOSTNAME && $MACHINE_TIER == hub`. MACHINE_TIER is
# declared per-host in .local-vars.
export PRIMARY_HOSTNAME=legion

# === App-specific (non-secret) ===
export TMP_S3_BUCKET=tmp-borza-public-cyx
export ASWAN_REMOTE=sscub-aswan-vsrv9
export BG_TMUX_SESSION=main-bg

# === Legacy alias (kept until create-service is updated to use DIEN_ROOT) ===
export SETUP_REPO="$DIEN_ROOT"
