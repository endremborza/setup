{
  "manifest_version": 2,
  "name": "LogSave",
  "version": "1.0",
  "description": "Send current page HTML to localhost",
  "permissions": ["activeTab", "tabs"],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "commands": {
    "log-me": {
      "suggested_key": { "default": "Ctrl+Shift+L" },
      "description": "Send page HTML to localhost"
    }
  },
  "browser_specific_settings": {
    "gecko": { "id": "logsave@localhost" }
  }
}
